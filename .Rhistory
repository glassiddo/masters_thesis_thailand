reduce(left_join, join_by(fire_id)) |>
summarise(
total_fires = n(),
# by day/night
!!!metrics_daynight,
# by satellite
!!!metrics_satellite,
# by satellite and day/night
!!!metrics_satellite_daynight,
# only high confidence fires
!!!metrics_confidence,
# by frp
!!!metrics_frp,
# by frp and satellite's overpass
!!!metrics_frp_aqua_day,
# by road quantiles
!!!metrics_road,
# by urban quantiles
!!!metrics_urban,
# by crop production
!!!metrics_crop_prod,
# by dominant crop
!!!metrics_dom_crop,
# # # by land use
!!!metrics_landuse,
.by = c(adm1_id, date)
)
View(metrics_road)
head(modis_landuse)
